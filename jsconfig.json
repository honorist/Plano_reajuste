{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "checkJs": false,
    "allowJs": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "maxNodeModuleJsDepth": 0,
    "lib": ["ES2022", "DOM"],
    "types": []
  },
  "include": ["src/**/*.js", "tests/**/*.js", "scripts/**/*.js"],
  "exclude": ["node_modules", "dist", "coverage", "src/lib/**"]
}
